predict(model, new_data =trans_df)$.pred
function(){
list(status = "Conexion exitosa a la API del precio de la casa",
time = Sys.time(),
username = Sys.getenv("USERNAME"))
}
function(precio_terreno, metros_habitables,banios,
antiguedad, metros_totales, dormitorios){
new_df <- data.frame(precio_terreno=precio_terreno, metros_habitables=metros_habitables,
banios=banios, antiguedad=antiguedad, metros_totales=metros_totales,
dormitorios=dormitorios)
trans_df <- data.frame(bake(transformer_var, new_data = new_df))
predict(model, new_data =trans_df)$.pred
}
