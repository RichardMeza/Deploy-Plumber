model <- readr::read_rds("./modelo_precio_rf.rds")
summary(model)
transformer_var <- readr::read_rds("./transformer_var.rds")
new_df <- data.frame(precio_terreno=4, metros_habitables=4,
banios=5, antiguedad=6, metros_totales=7,
dormitorios=8)
